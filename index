:root {
  --orange: #ff6b35;
  --orange-dark: #c94f00;
  --yellow: #f7c948;
  --yellow-dark: #e0a800;
  --green-wa: #25d366;
  --green-wa-dark: #1a9e4a;
  --bg: #fff9f5;
  --card: #ffffff;
  --text: #1a1a1a;
  --muted: #666;
  --border: rgba(0,0,0,0.1);
  --surface: #f5f0eb;
}

body {
  font-family: 'Nunito', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

/* ── HEADER ── */
header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 1rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 20px rgba(0,0,0,0.3);
}
.logo {
  font-family: 'Fredoka One', cursive;
  font-size: 1.8rem;
  color: var(--yellow);
  letter-spacing: 1px;
  text-shadow: 2px 2px 0 rgba(0,0,0,0.3);
}
.logo span { color: var(--orange); }
.header-badge {
  background: var(--orange);
  color: #fff;
  font-family: 'Fredoka One', cursive;
  font-size: 0.75rem;
  padding: 0.3rem 0.8rem;
  border-radius: 50px;
  letter-spacing: 0.5px;
}

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, #ff6b35 0%, #f7c948 50%, #ff9f1c 100%);
  background-size: 200% 200%;
  animation: gradShift 5s ease infinite;
  padding: 3rem 1.5rem 2.5rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
@keyframes gradShift {
  0%,100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}
.confetti { position: absolute; border-radius: 50%; animation: fall linear infinite; opacity: 0; }
@keyframes fall {
  0% { transform: translateY(-30px) rotate(0deg); opacity: 0.8; }
  100% { transform: translateY(110%) rotate(720deg); opacity: 0; }
}
.hero-phone {
  font-size: 5.5rem;
  display: block;
  animation: sway 3s ease-in-out infinite;
  filter: drop-shadow(0 8px 16px rgba(0,0,0,0.2));
}
@keyframes sway {
  0%,100% { transform: rotate(-6deg) scale(1); }
  50% { transform: rotate(6deg) scale(1.05); }
}
.hero h1 {
  font-family: 'Fredoka One', cursive;
  font-size: clamp(2.5rem, 8vw, 4rem);
  color: #fff;
  text-shadow: 4px 4px 0 rgba(0,0,0,0.15);
  margin: 0.25rem 0 0.5rem;
}
.hero p {
  color: rgba(255,255,255,0.92);
  font-size: 1.05rem;
  font-weight: 700;
  margin-bottom: 1rem;
}
.prize-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  color: var(--orange-dark);
  font-family: 'Fredoka One', cursive;
  font-size: 1.1rem;
  padding: 0.5rem 1.4rem;
  border-radius: 50px;
  box-shadow: 0 6px 0 var(--yellow-dark);
  animation: bounce 2s ease-in-out infinite;
}
@keyframes bounce {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-7px); }
}
.draw-tag {
  margin-top: 1rem;
  display: inline-block;
  background: rgba(0,0,0,0.2);
  color: #fff;
  font-size: 0.85rem;
  font-weight: 700;
  padding: 0.3rem 1rem;
  border-radius: 50px;
}

/* ── MAIN CONTAINER ── */
.container {
  max-width: 480px;
  margin: 0 auto;
  padding: 1.5rem 1rem 4rem;
}

/* ── STATS ── */
.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin: 1.5rem 0 0.75rem;
}
.stat-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 0.85rem 0.5rem;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.stat-val {
  font-family: 'Fredoka One', cursive;
  font-size: 1.6rem;
  color: var(--orange);
}
.stat-label {
  font-size: 10px;
  color: var(--muted);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-top: 2px;
}
.progress-wrap {
  background: var(--surface);
  border-radius: 20px;
  height: 16px;
  overflow: hidden;
  margin-bottom: 0.3rem;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--orange), var(--yellow));
  border-radius: 20px;
  width: 0;
  animation: growBar 2s ease forwards;
}
@keyframes growBar { to { width: 62%; } }
.progress-label {
  font-size: 12px;
  color: var(--muted);
  font-weight: 700;
  text-align: right;
}

/* ── COUNTDOWN ── */
.countdown-block {
  background: #1a1a2e;
  border-radius: 18px;
  padding: 1.25rem;
  margin: 1.25rem 0;
  text-align: center;
}
.countdown-title {
  font-family: 'Fredoka One', cursive;
  color: var(--yellow);
  font-size: 0.95rem;
  margin-bottom: 0.85rem;
}
.countdown-grid {
  display: flex;
  gap: 10px;
  justify-content: center;
}
.cd-unit {
  background: rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 0.6rem 0.9rem;
  min-width: 58px;
}
.cd-num {
  font-family: 'Fredoka One', cursive;
  font-size: 1.8rem;
  color: var(--yellow);
  line-height: 1;
}
.cd-lbl {
  font-size: 10px;
  color: rgba(255,255,255,0.55);
  font-weight: 700;
  text-transform: uppercase;
  margin-top: 3px;
}

/* ── SECTION CARD ── */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 1.35rem;
  margin: 1.25rem 0;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.card-title {
  font-family: 'Fredoka One', cursive;
  font-size: 1.2rem;
  color: var(--text);
  margin-bottom: 0.85rem;
}

/* ── TICKET GRID ── */
.ticket-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}
.t-opt {
  border: 2.5px solid var(--orange);
  border-radius: 14px;
  padding: 0.7rem 0.4rem;
  text-align: center;
  cursor: pointer;
  transition: all 0.15s;
  position: relative;
  background: #fff;
}
.t-opt:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(255,107,53,0.25); }
.t-opt.selected { background: var(--orange); color: #fff; transform: translateY(-2px); box-shadow: 0 4px 16px rgba(255,107,53,0.4); }
.t-opt.selected .t-save { background: var(--yellow); color: #7a4f00; }
.t-count { font-family: 'Fredoka One', cursive; font-size: 1.4rem; color: inherit; }
.t-label { font-size: 10px; font-weight: 700; color: var(--muted); margin: 1px 0; }
.t-opt.selected .t-label { color: rgba(255,255,255,0.8); }
.t-price { font-size: 12px; font-weight: 800; color: inherit; }
.t-save {
  display: inline-block;
  background: var(--yellow);
  color: #7a4f00;
  font-size: 9px;
  font-weight: 800;
  padding: 2px 5px;
  border-radius: 6px;
  margin-top: 3px;
}

/* ── MOMO TABS ── */
.momo-tabs { display: flex; gap: 10px; margin-bottom: 1rem; }
.momo-tab {
  flex: 1;
  padding: 0.65rem;
  border-radius: 12px;
  border: 2px solid var(--border);
  text-align: center;
  cursor: pointer;
  font-weight: 700;
  font-size: 13px;
  color: var(--muted);
  transition: all 0.15s;
  background: var(--surface);
}
.momo-tab.active { border-color: var(--orange); color: var(--orange); background: rgba(255,107,53,0.06); }
.momo-tab .tab-icon { font-size: 22px; display: block; margin-bottom: 2px; }

/* ── FORM ── */
.field { margin-bottom: 12px; }
.field label { font-size: 13px; font-weight: 700; color: var(--muted); display: block; margin-bottom: 5px; }
.field input {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 12px;
  padding: 0.7rem 1rem;
  font-size: 15px;
  font-family: 'Nunito', sans-serif;
  background: var(--surface);
  color: var(--text);
  outline: none;
  transition: border-color 0.15s;
}
.field input:focus { border-color: var(--orange); background: #fff; }

/* ── SUMMARY ── */
.summary {
  background: rgba(255,107,53,0.07);
  border: 1.5px dashed var(--orange);
  border-radius: 14px;
  padding: 1rem;
  margin: 1rem 0;
}
.sum-row { display: flex; justify-content: space-between; font-size: 13px; font-weight: 700; color: var(--muted); padding: 3px 0; }
.sum-total { display: flex; justify-content: space-between; font-family: 'Fredoka One', cursive; font-size: 1.15rem; color: var(--orange-dark); border-top: 1.5px dashed rgba(255,107,53,0.3); padding-top: 8px; margin-top: 6px; }

/* ── BUTTONS ── */
.btn-main {
  width: 100%;
  background: linear-gradient(135deg, var(--orange), var(--yellow));
  color: #fff;
  font-family: 'Fredoka One', cursive;
  font-size: 1.2rem;
  border: none;
  border-radius: 16px;
  padding: 1.05rem;
  cursor: pointer;
  box-shadow: 0 5px 0 var(--orange-dark);
  transition: all 0.15s;
  letter-spacing: 0.5px;
}
.btn-main:hover { transform: translateY(-2px); box-shadow: 0 7px 0 var(--orange-dark); }
.btn-main:active { transform: translateY(3px); box-shadow: 0 2px 0 var(--orange-dark); }
.btn-wa {
  width: 100%;
  background: var(--green-wa);
  color: #fff;
  font-family: 'Fredoka One', cursive;
  font-size: 1.15rem;
  border: none;
  border-radius: 16px;
  padding: 1rem;
  cursor: pointer;
  box-shadow: 0 5px 0 var(--green-wa-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: all 0.15s;
}
.btn-wa:hover { transform: translateY(-2px); box-shadow: 0 7px 0 var(--green-wa-dark); }
.btn-wa:active { transform: translateY(3px); box-shadow: 0 2px 0 var(--green-wa-dark); }
.btn-ghost {
  width: 100%;
  background: none;
  border: none;
  color: var(--muted);
  font-family: 'Nunito', sans-serif;
  font-weight: 700;
  font-size: 13px;
  padding: 0.6rem;
  cursor: pointer;
  margin-top: 6px;
}
.btn-ghost:hover { color: var(--orange); }

/* ── HOW IT WORKS ── */
.how-step { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 16px; }
.how-num {
  width: 34px; height: 34px;
  border-radius: 50%;
  background: var(--orange);
  color: #fff;
  font-family: 'Fredoka One', cursive;
  font-size: 1rem;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 3px 0 var(--orange-dark);
}
.how-text strong { display: block; font-size: 14px; font-weight: 800; color: var(--text); }
.how-text span { font-size: 12px; color: var(--muted); }

/* ── TRUST BADGES ── */
.trust-row {
  display: flex;
  gap: 10px;
  justify-content: center;
  margin: 0.5rem 0 1.5rem;
  flex-wrap: wrap;
}
.trust-badge {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 50px;
  padding: 0.35rem 0.9rem;
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 5px;
}

/* ── FOOTER ── */
footer {
  background: #1a1a2e;
  color: rgba(255,255,255,0.5);
  text-align: center;
  padding: 1.5rem 1rem;
  font-size: 12px;
  font-weight: 600;
}
footer a { color: var(--yellow); text-decoration: none; }

/* ══════════════════════════════════
   MODAL FLOW
══════════════════════════════════ */
.overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  align-items: flex-end;
  justify-content: center;
  padding: 0;
}
.overlay.open { display: flex; }
.modal {
  background: var(--card);
  border-radius: 24px 24px 0 0;
  padding: 1.5rem 1.25rem 2rem;
  width: 100%;
  max-width: 480px;
  max-height: 92vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(40px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.modal-drag {
  width: 40px; height: 4px;
  background: var(--border);
  border-radius: 4px;
  margin: 0 auto 1.25rem;
}

/* step indicators */
.step-track { display: flex; align-items: center; justify-content: center; gap: 6px; margin-bottom: 1.5rem; }
.s-dot {
  width: 30px; height: 30px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Fredoka One', cursive;
  font-size: 0.9rem;
  background: var(--surface);
  color: var(--muted);
  border: 2px solid var(--border);
  transition: all 0.3s;
}
.s-dot.active { background: var(--orange); color: #fff; border-color: var(--orange); }
.s-dot.done { background: var(--green-wa); color: #fff; border-color: var(--green-wa); }
.s-line { flex: 1; height: 2px; background: var(--border); border-radius: 2px; transition: background 0.3s; }
.s-line.done { background: var(--green-wa); }

.panel { display: none; animation: fadeUp 0.25s ease; }
.panel.active { display: block; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* order review */
.order-card {
  background: rgba(255,107,53,0.07);
  border-radius: 14px;
  padding: 1rem;
  margin-bottom: 1rem;
}
.o-row { display: flex; justify-content: space-between; font-size: 14px; font-weight: 700; padding: 5px 0; color: var(--text); border-bottom: 1px solid rgba(0,0,0,0.05); }
.o-row:last-of-type { border: none; }
.o-total { display: flex; justify-content: space-between; font-family: 'Fredoka One', cursive; font-size: 1.15rem; color: var(--orange-dark); border-top: 1.5px dashed rgba(255,107,53,0.3); padding-top: 8px; margin-top: 6px; }

/* payment instructions */
.pay-card {
  background: var(--surface);
  border-radius: 14px;
  padding: 1rem;
  margin-bottom: 1rem;
}
.pay-header { display: flex; align-items: center; gap: 12px; margin-bottom: 0.85rem; }
.pay-logo { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
.pay-logo.airtel { background: #e30613; }
.pay-logo.mtn { background: #ffc200; }
.copy-row {
  background: #fff;
  border: 1.5px dashed var(--orange);
  border-radius: 12px;
  padding: 0.6rem 1rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 8px 0;
}
.copy-lbl { font-size: 10px; color: var(--muted); font-weight: 700; text-transform: uppercase; }
.copy-val { font-family: 'Fredoka One', cursive; font-size: 1.2rem; color: var(--orange-dark); letter-spacing: 2px; }
.copy-btn {
  background: var(--orange);
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 5px 12px;
  font-size: 12px;
  font-family: 'Nunito', sans-serif;
  font-weight: 700;
  cursor: pointer;
  flex-shrink: 0;
}
.pay-steps { list-style: none; margin-top: 0.85rem; }
.pay-steps li { display: flex; gap: 10px; font-size: 13px; font-weight: 600; color: var(--text); padding: 5px 0; align-items: flex-start; }
.pay-steps li .n {
  width: 22px; height: 22px;
  border-radius: 50%;
  background: var(--orange);
  color: #fff;
  font-size: 11px;
  display: inline-flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-family: 'Fredoka One', cursive;
  margin-top: 1px;
}

/* whatsapp step */
.wa-bubble {
  background: #e7fce5;
  border: 1px solid #b8f0c0;
  border-radius: 16px 16px 16px 4px;
  padding: 1rem;
  margin-bottom: 1rem;
  font-size: 13px;
  color: #1a3d1f;
  line-height: 1.65;
  white-space: pre-wrap;
}
.wa-bubble strong { color: #1a7a3a; display: block; margin-bottom: 6px; }
.wa-time { font-size: 11px; color: #7a9a7e; text-align: right; margin-top: 6px; }

/* confirmed */
.confirmed-hero { text-align: center; padding: 0.5rem 0 1rem; }
.big-tick { font-size: 4rem; animation: pop 0.5s ease; display: block; }
@keyframes pop {
  0% { transform: scale(0) rotate(-10deg); }
  70% { transform: scale(1.2) rotate(5deg); }
  100% { transform: scale(1) rotate(0deg); }
}

.note { font-size: 11px; color: var(--muted); text-align: center; margin-top: 0.75rem; }

/* ── RESPONSIVE ── */
@media (min-width: 481px) {
  .overlay { align-items: center; padding: 1rem; }
  .modal { border-radius: 24px; max-height: 88vh; }
}

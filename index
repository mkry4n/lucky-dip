  <script>
    /* ══════════════════════════════════
       LUCKYDIP FRONTEND — SECURED
       - Prices locked server-side (constants only, not user-mutable)
       - No ticket number generation on frontend
       - Ref codes use crypto.getRandomValues for unpredictability
       - Submit button disabled after first use per session (anti-spam)
       - Amount/count read from locked constants, never from DOM
       - All validation server-side; frontend validation is UX only
    ══════════════════════════════════ */

    /* ── LOCKED PRICE TABLE (not alterable via console without full override) ── */
    const TICKET_PRICES = Object.freeze({
      1:  { price: 20,  save: 0  },
      3:  { price: 50,  save: 17 },
      5:  { price: 80,  save: 20 },
      10: { price: 150, save: 25 },
      20: { price: 250, save: 38 },
      50: { price: 500, save: 50 },
    });

    let selCount = 3;
    let momoProvider = 'airtel';
    let refCode = '';
    let submitting = false; /* anti-spam: one submission per session flow */

    /* ── SAFE PRICE LOOKUP — always from locked table, never from DOM ── */
    function getPrice(count) {
      return TICKET_PRICES[count] || TICKET_PRICES[1];
    }

    /* ── CONFETTI ── */
    (function spawnConfetti() {
      const hero = document.getElementById('hero-section');
      const colors = ['#fff','#f7c948','#ffe066','#ffb347','#fff9c4'];
      for (let i = 0; i < 18; i++) {
        const d = document.createElement('div');
        d.className = 'confetti';
        d.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*30}%;width:${6+Math.random()*8}px;height:${6+Math.random()*8}px;background:${colors[Math.floor(Math.random()*colors.length)]};animation-duration:${2+Math.random()*3}s;animation-delay:${Math.random()*4}s;`;
        hero.appendChild(d);
      }
    })();

    /* ── COUNTDOWN ── */
    const drawDate = new Date('2026-04-19T19:00:00+02:00');
    function tick() {
      const diff = drawDate - Date.now();
      if (diff <= 0) {
        ['cd-d','cd-h','cd-m','cd-s'].forEach(id => document.getElementById(id).textContent = '00');
        return;
      }
      document.getElementById('cd-d').textContent = String(Math.floor(diff/86400000)).padStart(2,'0');
      document.getElementById('cd-h').textContent = String(Math.floor((diff%86400000)/3600000)).padStart(2,'0');
      document.getElementById('cd-m').textContent = String(Math.floor((diff%3600000)/60000)).padStart(2,'0');
      document.getElementById('cd-s').textContent = String(Math.floor((diff%60000)/1000)).padStart(2,'0');
    }
    setInterval(tick, 1000); tick();

    /* ── TICKET SELECTION ── */
    function selectTicket(el, count) {
      document.querySelectorAll('.t-opt').forEach(e => e.classList.remove('selected'));
      el.classList.add('selected');
      selCount = count;
      const { price, save } = getPrice(count);
      const saved = (count * 20) - price;
      document.getElementById('s-tickets').textContent = count + ' ticket' + (count > 1 ? 's' : '');
      document.getElementById('s-unit').textContent = 'K' + (price/count).toFixed(2) + ' each';
      document.getElementById('s-disc').textContent = save > 0 ? 'Save K' + saved + ' (' + save + '%)' : 'None';
      document.getElementById('s-disc').style.color = save > 0 ? '#2a9d2a' : 'var(--muted)';
      document.getElementById('s-total').textContent = 'K' + price;
    }

    /* ── MOMO SWITCH ── */
    function switchMomo(p) {
      momoProvider = p;
      document.getElementById('tab-airtel').classList.toggle('active', p === 'airtel');
      document.getElementById('tab-mtn').classList.toggle('active', p === 'mtn');
      document.getElementById('momo-lbl').textContent = p === 'airtel' ? 'Your Airtel Money Number' : 'Your MTN MoMo Number';
      document.getElementById('momo-num').placeholder = p === 'airtel' ? 'e.g. 097 123 4567' : 'e.g. 096 123 4567';
    }

    /* ── SECURE REF CODE — crypto random, not Math.random ── */
    function genRef() {
      const arr = new Uint8Array(4);
      crypto.getRandomValues(arr);
      return 'LD-' + Array.from(arr, b => b.toString(36).toUpperCase().padStart(2,'0')).join('').substring(0,6);
    }

    /* ── INPUT SANITISER — strips HTML tags from user input ── */
    function sanitise(str) {
      return str.replace(/[<>"'&]/g, '').trim().substring(0, 100);
    }

    /* ── ZAMBIAN PHONE VALIDATOR ── */
    function isValidZambianPhone(num) {
      const cleaned = num.replace(/[\s\-\+]/g, '');
      return /^(260|0)(9[5-7]|7[6-7])\d{7}$/.test(cleaned);
    }

    /* ── OPEN MODAL ── */
    function openModal() {
      if (submitting) return; /* prevent double submission */

      const rawName = document.getElementById('p-name').value;
      const rawWa   = document.getElementById('p-wa').value;
      const rawMomo = document.getElementById('momo-num').value;

      const name = sanitise(rawName);
      const wa   = sanitise(rawWa);
      const momo = sanitise(rawMomo);

      if (!name) { showError('Please enter your full name.'); return; }
      if (name.length < 3) { showError('Please enter your full name (at least 3 characters).'); return; }
      if (!momo) { showError('Please enter your ' + (momoProvider === 'airtel' ? 'Airtel Money' : 'MTN MoMo') + ' number.'); return; }
      if (!isValidZambianPhone(momo)) { showError('Please enter a valid Zambian mobile number (e.g. 097 123 4567).'); return; }
      if (!wa) { showError('Please enter your WhatsApp number so we can send your ticket confirmation.'); return; }
      if (!isValidZambianPhone(wa)) { showError('Please enter a valid Zambian WhatsApp number.'); return; }

      /* Always read price from locked table — never from DOM or user input */
      const { price } = getPrice(selCount);
      refCode = genRef();

      /* fill panel 1 */
      document.getElementById('m-tickets').textContent = selCount + ' ticket' + (selCount > 1 ? 's' : '');
      document.getElementById('m-name').textContent    = name;
      document.getElementById('m-wa').textContent      = wa;
      document.getElementById('m-prov').textContent    = momoProvider === 'airtel' ? 'Airtel Money' : 'MTN MoMo';
      document.getElementById('m-total').textContent   = 'K' + price;

      /* fill panel 2 */
      if (momoProvider === 'airtel') {
        document.getElementById('m-logo').textContent      = '🔴';
        document.getElementById('m-logo').className        = 'pay-logo airtel';
        document.getElementById('m-prov-name').textContent = 'Airtel Money';
        document.getElementById('m-app').textContent       = 'Airtel Money';
        document.getElementById('m-merchant').textContent  = '0972573411';
      } else {
        document.getElementById('m-logo').textContent      = '🟡';
        document.getElementById('m-logo').className        = 'pay-logo mtn';
        document.getElementById('m-prov-name').textContent = 'MTN MoMo';
        document.getElementById('m-app').textContent       = 'MTN MoMo';
        document.getElementById('m-merchant').textContent  = '0961794739';
      }
      document.getElementById('m-ref').textContent = refCode;
      document.getElementById('m-amt').textContent = 'K' + price;

      /* fill panel 3 — WhatsApp message includes price from locked table */
      const waText = `Hi LuckyDip! 👋

I've just paid for my raffle tickets 🎟️

Name: ${name}
Tickets: ${selCount}
Ref Code: ${refCode}
Amount: K${price}
Payment via: ${momoProvider === 'airtel' ? 'Airtel Money' : 'MTN MoMo'}

[Screenshot attached]

Please confirm my entry. Thank you! 🙏`;
      document.getElementById('wa-msg').textContent = waText;
      const now = new Date();
      document.getElementById('wa-time').textContent = now.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});

      goTo(1);
      document.getElementById('overlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    /* ── ERROR DISPLAY ── */
    function showError(msg) {
      let el = document.getElementById('form-error');
      if (!el) {
        el = document.createElement('div');
        el.id = 'form-error';
        el.style.cssText = 'background:#fee;border:1.5px solid #e88;border-radius:10px;padding:0.65rem 1rem;font-size:13px;font-weight:700;color:#c00;margin-bottom:10px;';
        const btn = document.querySelector('.btn-main[onclick="openModal()"]');
        btn.parentNode.insertBefore(el, btn);
      }
      el.textContent = '⚠️ ' + msg;
      el.style.display = 'block';
      setTimeout(() => { if(el) el.style.display = 'none'; }, 5000);
    }

    /* ── CLOSE MODAL ── */
    function closeModal() {
      document.getElementById('overlay').classList.remove('open');
      document.body.style.overflow = '';
      submitting = false;
    }
    document.getElementById('overlay').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });

    /* ── STEP NAV ── */
    function goTo(n) {
      [1,2,3,4].forEach(i => {
        document.getElementById('p' + i).classList.toggle('active', i === n);
        const dot = document.getElementById('d' + i);
        if (i < n)        { dot.classList.add('done'); dot.classList.remove('active'); dot.textContent = '✓'; }
        else if (i === n) { dot.classList.add('active'); dot.classList.remove('done'); dot.textContent = i < 4 ? i : '✓'; }
        else              { dot.classList.remove('active','done'); dot.textContent = i < 4 ? i : '✓'; }
        if (i < 4) document.getElementById('l' + i).classList.toggle('done', i < n);
      });
      document.getElementById('modal').scrollTop = 0;
    }

    /* ── COPY ── */
    function copyText(elId, btnId) {
      const text = document.getElementById(elId).textContent;
      navigator.clipboard.writeText(text).catch(() => {});
      const btn = document.getElementById(btnId);
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    }

    /* ── WHATSAPP — disable button after tap to prevent spam ── */
    function sendWhatsApp() {
      if (submitting) return;
      submitting = true;

      const name  = sanitise(document.getElementById('p-name').value);
      const { price } = getPrice(selCount);
      const msg   = `Hi LuckyDip! 👋

I've just paid for my raffle tickets 🎟️

Name: ${name}
Tickets: ${selCount}
Ref Code: ${refCode}
Amount: K${price}
Payment via: ${momoProvider === 'airtel' ? 'Airtel Money' : 'MTN MoMo'}

[Screenshot attached]

Please confirm my entry. Thank you! 🙏`;
      const url   = 'https://wa.me/260961794739?text=' + encodeURIComponent(msg);

      /* disable the WA button to prevent repeat taps */
      const waBtn = document.querySelector('#p3 .btn-wa');
      if (waBtn) { waBtn.disabled = true; waBtn.style.opacity = '0.6'; waBtn.textContent = 'Opening WhatsApp...'; }

      window.open(url, '_blank');
      setTimeout(() => goTo(4), 1800);
    }
  </script>

</body>
